      "parameters": {
        "jsCode": "// Entrada: items = asesores filtrados desde Supabase\n// Cada item tiene: id, nombre, proyecto_asignado, correo, celular, last_assigned_at\n\nconst asesores = items.map(item => item.json);\n\n// Ordenar por last_assigned_at (NULL = mÃ¡s antiguo)\nasesores.sort((a, b) => {\n  if (!a.last_assigned_at) return -1;\n  if (!b.last_assigned_at) return 1;\n  return new Date(a.last_assigned_at) - new Date(b.last_assigned_at);\n});\n\n// Tomar el primero\nconst seleccionado = asesores[0];\n\n// Devolver el asesor seleccionado\nreturn [{ json: seleccionado }];\n\n"
      },
