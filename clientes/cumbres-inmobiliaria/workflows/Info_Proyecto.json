    {
      "parameters": {
        "jsCode": "// ===== OBTENER DATOS =====\nconst verificacion = $('Verificar ReasignaciÃ³n Asesor').first().json;\nconst leadExistente = $('Informacion del Lead').first().json;\nconst inputNuevo = $('When Executed by Another Workflow').first().json;\n\n// ===== CONSTRUIR OUTPUT =====\nreturn [{\n  json: {\n    // ===== IDENTIFICACIÃ“N DEL LEAD =====\n    session_id: verificacion.session_id,\n    \n    // ===== CRÃTICO: MANTENER EL ASESOR ACTUAL =====\n    // Este campo \"nombre\" es el que usa \"Actualizar Datos Lead\"\n    // para actualizar asesor_asignado\n    nombre: verificacion.asesor_actual,\n    \n    // ===== DATOS DEL ASESOR (mantener existentes) =====\n    celular: leadExistente.asesor_celular,\n    correo: leadExistente.asesor_correo,\n    \n    // ===== DATOS DEL LEAD (actualizar si hay nuevos) =====\n    nombres: inputNuevo.nombres || leadExistente.nombres,\n    apellidos: inputNuevo.apellidos || leadExistente.apellidos,\n    DNI: inputNuevo.DNI || leadExistente.dni_ce,\n    correo_lead: inputNuevo.correo || leadExistente.email,\n    proyecto: inputNuevo.proyecto || leadExistente.proyect,\n    resumen: inputNuevo.resumen || leadExistente.resumen,\n    \n    // PrecalificaciÃ³n (si existe en el input)\n    precalificacion: inputNuevo.precalificacion || '',\n    \n    // ===== FLAGS PARA DEBUGGING =====\n    asesor_mantenido: true,\n    ruta_flujo: 'FALSE - Mantener asesor existente',\n    motivo: 'Lead ya tiene asesor y sigue en la misma zona'\n  }\n}];"
      },
