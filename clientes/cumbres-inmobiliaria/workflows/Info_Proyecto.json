    {
      "parameters": {
        "jsCode": "// ===== MAPEO DE PROYECTOS A CIUDADES =====\nconst CIUDAD_POR_PROYECTO = {\n  'Villanova 5': 'Callao',\n  'Villa Monumental A': 'Callao',\n  'AndalucÃ­a': 'Trujillo',\n  'Villa del Puerto 1': 'Chancay'\n};\n\n// ===== OBTENER DATOS DEL LEAD DESDE SUPABASE =====\n// Leer directamente del nodo \"Informacion del Lead\" (GET de Supabase)\nconst leadExistente = $('Informacion del Lead').first().json;\n\n// Obtener el proyecto nuevo del input del workflow\nconst inputNuevo = $('When Executed by Another Workflow').first().json;\nconst proyectoNuevo = inputNuevo.proyecto;\n\n// Obtener el proyecto actual del lead en la BD\nconst proyectoActual = leadExistente.proyect || '';\n\n// ===== CONVERTIR PROYECTOS A CIUDADES =====\nconst ciudadNueva = CIUDAD_POR_PROYECTO[proyectoNuevo] || 'Desconocida';\nconst ciudadActual = CIUDAD_POR_PROYECTO[proyectoActual] || 'Desconocida';\n\n// ===== VERIFICAR SI TIENE ASESOR =====\nconst asesorActual = leadExistente.asesor_asignado || '';\nconst tieneAsesor = asesorActual.trim() !== '' && \n                    asesorActual !== 'sin asignar' &&\n                    asesorActual !== null;\n\n// ===== LÃ“GICA DE DECISIÃ“N =====\nconst mismaZona = ciudadNueva === ciudadActual;\nconst debeReasignar = !tieneAsesor || !mismaZona;\n\n// ===== SALIDA LIMPIA =====\nreturn [{\n  json: {\n    // Datos del lead desde Supabase\n    session_id: leadExistente.session_id,\n    proyect: proyectoActual,\n    nombres: leadExistente.nombres,\n    apellidos: leadExistente.apellidos,\n    \n    // Campos de decisiÃ³n (los que necesitas)\n    proyecto_asesor: proyectoNuevo,\n    tiene_asesor: tieneAsesor,\n    asesor_actual: asesorActual,\n    debe_reasignar: debeReasignar\n  }\n}];"
      },
